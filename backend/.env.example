# --- SUPABASE CONFIGURATION ---
# Found in Supabase Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-key-string-here

# --- AUTHENTICATION ---
# Generate a random string using: openssl rand -hex 32
SECRET_KEY=your-32-character-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- DATABASE CONFIG (Required by backend/database.py) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@db.your-id.supabase.co:5432/postgres

# --- ENVIRONMENT ---
PORT=8000
DEBUG=False
FRONTEND_URL=http://localhost:5173